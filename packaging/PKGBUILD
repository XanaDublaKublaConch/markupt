# Maintainer: (unset)
pkgname=markdownviewer
pkgver=0.1.0
pkgrel=1
pkgdesc="A lightweight native Markdown viewer for KDE Plasma"
arch=('x86_64')
license=('MIT')
depends=('qt6-base' 'kdbusaddons' 'syntax-highlighting' 'kwindowsystem' 'breeze-icons')
makedepends=('cmake' 'extra-cmake-modules')
source=()
sha256sums=()

build() {
    cmake -B build -S "$startdir/.." \
        -DCMAKE_BUILD_TYPE=Release \
        -DCMAKE_INSTALL_PREFIX=/usr
    cmake --build build
}

package() {
    DESTDIR="$pkgdir" cmake --install build
}
